# =============================================================================
# BestSeller — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
MINIMAX_API_KEY=your-minimax-key-here
NVIDIA_API_KEY=nvapi-your-nvidia-key-here
ARK_API_KEY=your-volcengine-ark-key-here

# Optional providers
AZURE_API_KEY=your-azure-api-key-here
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-01
COHERE_API_KEY=your-cohere-key-here
GROQ_API_KEY=gsk_your-key-here
TOGETHERAI_API_KEY=your-together-key-here
HUGGINGFACE_API_KEY=hf_your-key-here

# -----------------------------------------------------------------------------
# PostgreSQL
# PostgreSQL is the primary and only source-of-truth database.
# -----------------------------------------------------------------------------

BESTSELLER__DATABASE__URL=postgresql+asyncpg://bestseller:bestseller@localhost:5432/bestseller

# Optional per-environment overrides
# BESTSELLER__DATABASE__POOL_SIZE=20
# BESTSELLER__DATABASE__MAX_OVERFLOW=20
# BESTSELLER__DATABASE__STATEMENT_TIMEOUT_MS=60000

# -----------------------------------------------------------------------------
# Retrieval
# pgvector runs inside PostgreSQL.
# -----------------------------------------------------------------------------

# BESTSELLER__RETRIEVAL__EMBEDDING_MODEL=BAAI/bge-m3
# BESTSELLER__RETRIEVAL__EMBEDDING_DIMENSIONS=1024
# BESTSELLER__RETRIEVAL__TOP_K=12

# -----------------------------------------------------------------------------
# Runtime switches
# -----------------------------------------------------------------------------

# Optional preset for start.sh auto-wiring.
# Supported presets: gemini, minimax, minimax-quality, nvidia,
# volcengine-coding (aliases: byte-coding, bytedance-coding, ark-coding,
# coding-plan). Each preset routes planner/writer/critic/summarizer/editor
# through that provider's OpenAI-compatible endpoint.
# BESTSELLER_LLM_PROVIDER=gemini
#
# NVIDIA NIM hosted API defaults:
# BESTSELLER_LLM_PROVIDER=nvidia
# NVIDIA_LLM_MODEL=z-ai/glm-5.1
# NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
#
# MiniMax 429/quota fallback to NVIDIA GLM-5.1. With this enabled and
# NVIDIA_API_KEY filled, each process temporarily routes to NVIDIA after
# a MiniMax 429, then probes MiniMax again after the cooldown.
# BESTSELLER__LLM__RETRY__RATE_LIMIT_FALLBACK_ENABLED=true
# BESTSELLER__LLM__RETRY__RATE_LIMIT_FALLBACK_COOLDOWN_SECONDS=300
# BESTSELLER__LLM__WRITER__RATE_LIMIT_FALLBACK_MODEL=openai/z-ai/glm-5.1
# BESTSELLER__LLM__WRITER__RATE_LIMIT_FALLBACK_API_BASE=https://integrate.api.nvidia.com/v1
# BESTSELLER__LLM__WRITER__RATE_LIMIT_FALLBACK_API_KEY_ENV=NVIDIA_API_KEY
#
# Volcengine Ark Coding Plan defaults:
# BESTSELLER_LLM_PROVIDER=volcengine-coding
# ARK_CODING_MODEL=ark-code-latest
# ARK_CODING_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3
#
# BESTSELLER__LLM__MOCK=true
# BESTSELLER__LOGGING__LEVEL=DEBUG
# BESTSELLER__OUTPUT__BASE_DIR=/tmp/bestseller-output

# -----------------------------------------------------------------------------
# Artifact Store
# -----------------------------------------------------------------------------

# Local mode
# BESTSELLER__ARTIFACT_STORE__MODE=local
# BESTSELLER__ARTIFACT_STORE__LOCAL_DIR=./artifacts

# S3 mode
# BESTSELLER__ARTIFACT_STORE__MODE=s3
# BESTSELLER__ARTIFACT_STORE__S3__BUCKET=my-bestseller-artifacts
# BESTSELLER__ARTIFACT_STORE__S3__REGION=ap-southeast-1
# BESTSELLER__ARTIFACT_STORE__S3__PREFIX=bestseller

# -----------------------------------------------------------------------------
# Observability / Tracing (optional)
# -----------------------------------------------------------------------------

# LANGSMITH_API_KEY=ls__your-key-here
# LANGSMITH_PROJECT=bestseller
# LANGSMITH_TRACING_V2=true

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# -----------------------------------------------------------------------------
# Docker Compose Port Overrides
# -----------------------------------------------------------------------------

# DB_PORT=5432
# REDIS_PORT=6379
# API_PORT=8000
# MCP_PORT=3000
# WEB_PORT=8787
# WORKER_REPLICAS=2

# -----------------------------------------------------------------------------
# Redis (API server + worker)
# -----------------------------------------------------------------------------

# BESTSELLER__REDIS__URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------

# BESTSELLER__API__CORS_ORIGINS=["http://localhost:3000","http://localhost:8787"]

# -----------------------------------------------------------------------------
# Publishing encryption key
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# -----------------------------------------------------------------------------

# BESTSELLER_ENCRYPTION_KEY=your-32-byte-base64-fernet-key-here
