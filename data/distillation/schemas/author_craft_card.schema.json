    "status",
    "style_safety_policy",
    "pov_and_distance",
    "sentence_rhythm",
    "paragraphing",
    "dialogue_system",
    "description_strategy",
    "exposition_strategy",
    "emotional_temperature",
    "hooking_and_transitions",
    "adaptation_guidelines",
    "taboo_copy_signals",
    "confidence"
  ],
  "properties": {
