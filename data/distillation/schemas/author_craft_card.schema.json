    "source_type": { "type": "string" },
    "status": { "type": "string" },
    "style_safety_policy": { "type": "string" },
    "pov_and_distance": { "type": "string" },
    "sentence_rhythm": { "type": "array", "items": { "type": "string" } },
    "paragraphing": { "type": "array", "items": { "type": "string" } },
    "dialogue_system": { "type": "array", "items": { "type": "string" } },
